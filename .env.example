# Copy to .env and fill in both values from a signed-in browser request to
# https://subscription.cookunity.com/menu-service/graphql (DevTools → Network →
# right-click request → Copy → Copy as cURL). Both values expire roughly every
# 24h — refresh when the script errors with 401 or "Valid user needed".

# JWT from the `authorization:` header (without the `Bearer ` prefix is fine).
CU_AUTH_TOKEN=

# Full value of the `cookie:` request header. Must include `appSession=...`.
CU_COOKIE=

# Cart UUID from the cart endpoint URL:
#   https://subscription.cookunity.com/sdui-service/cart/v2/<UUID>/products
# Only needed for ./serve.py (the interactive add-to-cart page).
CU_CART_ID=

# Optional: the host's LAN IP (for the startup banner when running in Docker).
# On macOS: `ipconfig getifaddr en0`. If unset, the server best-guesses, which
# is wrong inside a container — you'll see the container IP instead of your Mac's.
CU_LAN_IP=
